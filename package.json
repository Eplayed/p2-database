{
  "name": "p2-database",
  "version": "1.0.0",
  "main": "merge_data.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",

    "dev": "NODE_ENV=dev node run_crawler.js",
    "prod": "NODE_ENV=production node run_crawler.js",

    "cron:dev": "NODE_ENV=dev node run_translate_crawler.js",
    "cron:prod": "NODE_ENV=production node run_translate_crawler.js",

    "start": "npm run prod",
    "start:dev": "npm run dev",

    "crawl:all": "node run_crawler.js --all",
    "crawl:essence": "node run_crawler.js --essence",
    "crawl:hot": "node run_crawler.js --hot",
    "crawl:translate": "node run_crawler.js --translate",
    "crawl:news": "node auto_browser/crawl_news.js",
    "crawl:news:detail": "node auto_browser/crawl_news_detail.js",
    "crawl:news:all": "node auto_browser/crawl_news_with_details.js",

    "v2": "node crawlers/run.js",
    "v2:all": "node crawlers/run.js --all",
    "v2:dict": "node crawlers/run.js --dict",
    "v2:ladder": "NODE_ENV=production node crawlers/run.js --ladder",
    "v2:ladder:dev": "NODE_ENV=dev node crawlers/run.js --ladder",
    "v2:dev": "NODE_ENV=dev node crawlers/run.js --all",
    "v2:prod": "NODE_ENV=production node crawlers/run.js --all"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "PoE2 流放之路2 数据爬虫 - 整合踩蘑菇精华帖、天梯翻译、热门BD等功能",
  "dependencies": {
    "ali-oss": "^6.23.0",
    "dotenv": "^17.4.2",
    "https-proxy-agent": "^7.0.6",
    "protobufjs": "^7.5.4",
    "puppeteer": "^22.0.0"
  }
}
