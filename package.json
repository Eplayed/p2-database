{
  "name": "p2-database",
  "version": "1.0.0",
  "main": "merge_data.js",
  "scripts": {
    "test": "node --test test/*.test.js",
    "start": "NODE_ENV=production node crawlers/run.js",
    "dev": "NODE_ENV=dev node crawlers/run.js",
    "dashboard": "node --watch dashboard/server.js",
    "crawl": "node crawlers/run.js",
    "crawl:all": "node crawlers/run.js --all",
    "crawl:dict": "node crawlers/run.js --dict",
    "crawl:ladder": "NODE_ENV=production node crawlers/run.js --ladder",
    "crawl:ladder:dev": "NODE_ENV=dev node crawlers/run.js --ladder",
    "refresh:ladder-distribution": "NODE_ENV=production node scripts/refresh_ladder_distribution.js && NODE_ENV=production node scripts/aggregate_analysis.js && NODE_ENV=production node scripts/upload_analysis.js",
    "refresh:ladder-distribution:dev": "NODE_ENV=dev node scripts/refresh_ladder_distribution.js && NODE_ENV=dev node scripts/aggregate_analysis.js",
    "build:ladder-index": "NODE_ENV=production node scripts/build_ladder_build_index.js",
    "build:ladder-index:dev": "NODE_ENV=dev node scripts/build_ladder_build_index.js",
    "crawl:trees": "node crawlers/run.js --trees",
    "crawl:essence": "node crawlers/run.js --essence",
    "crawl:patch05": "NODE_ENV=production node crawlers/patch05/index.js",
    "crawl:patch05:dev": "NODE_ENV=dev node crawlers/patch05/index.js",
    "crawl:patch05:economy": "NODE_ENV=production node crawlers/patch05/economy.js",
    "crawl:patch05:economy:dev": "NODE_ENV=dev node crawlers/patch05/economy.js",
    "crawl:patch05:with-economy": "NODE_ENV=production node crawlers/patch05/run_with_economy.js",
    "crawl:patch05:with-economy:dev": "NODE_ENV=dev node crawlers/patch05/run_with_economy.js",
    "data:patch05:publish": "NODE_ENV=production node auto_browser/crawl_news_with_details.js && NODE_ENV=production node crawlers/patch05/run_with_economy.js && NODE_ENV=production node crawlers/story-guide/index.js && NODE_ENV=production node -e \"require('./auto_browser/upload_to_oss')()\"",
    "data:patch05:publish:dev": "NODE_ENV=dev node auto_browser/crawl_news_with_details.js && NODE_ENV=dev node crawlers/patch05/run_with_economy.js && NODE_ENV=dev node crawlers/story-guide/index.js && NODE_ENV=dev node -e \"require('./auto_browser/upload_to_oss')()\"",
    "crawl:story-guide": "NODE_ENV=production node crawlers/story-guide/index.js",
    "crawl:story-guide:dev": "NODE_ENV=dev node crawlers/story-guide/index.js",
    "crawl:story-guide:upload": "NODE_ENV=production node crawlers/story-guide/index.js --upload",
    "crawl:story-guide:upload:dev": "NODE_ENV=dev node crawlers/story-guide/index.js --upload",
    "crawl:news": "NODE_ENV=production node auto_browser/crawl_news.js",
    "crawl:news:dev": "NODE_ENV=dev node auto_browser/crawl_news.js",
    "crawl:news:detail": "node auto_browser/crawl_news_detail.js",
    "crawl:news:all": "NODE_ENV=production node auto_browser/crawl_news_with_details.js",
    "crawl:news:all:dev": "NODE_ENV=dev node auto_browser/crawl_news_with_details.js",
    "crawl:economy": "NODE_ENV=production node auto_browser/crawl_economy.js",
    "crawl:economy:dev": "NODE_ENV=dev node auto_browser/crawl_economy.js",
    "crawl:economy:ninja": "NODE_ENV=production node crawlers/economy/ninja_digest.js",
    "crawl:economy:ninja:dev": "NODE_ENV=dev node crawlers/economy/ninja_digest.js",
    "crawl:cn-market:dd373": "NODE_ENV=production node crawlers/cn-market/dd373_currency.js",
    "crawl:cn-market:dd373:dev": "NODE_ENV=dev node crawlers/cn-market/dd373_currency.js",
    "build:problem-guides": "NODE_ENV=production node scripts/build_problem_guides.js",
    "build:problem-guides:dev": "NODE_ENV=dev node scripts/build_problem_guides.js",
    "data:cn-market:publish": "NODE_ENV=production node crawlers/cn-market/dd373_currency.js && NODE_ENV=production node -e \"require('./auto_browser/upload_to_oss')()\"",
    "data:cn-market:publish:dev": "NODE_ENV=dev node crawlers/cn-market/dd373_currency.js && NODE_ENV=dev node -e \"require('./auto_browser/upload_to_oss')()\"",
    "data:economy:publish": "NODE_ENV=production node crawlers/economy/ninja_digest.js && NODE_ENV=production node crawlers/patch05/index.js && NODE_ENV=production node -e \"require('./auto_browser/upload_to_oss')()\"",
    "data:economy:publish:dev": "NODE_ENV=dev node crawlers/economy/ninja_digest.js && NODE_ENV=dev node crawlers/patch05/index.js && NODE_ENV=dev node -e \"require('./auto_browser/upload_to_oss')()\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "PoE2 流放之路2 数据爬虫 - 天梯数据、翻译字典、踩蘑菇精华帖等",
  "dependencies": {
    "ali-oss": "^6.23.0",
    "dotenv": "^17.4.2",
    "https-proxy-agent": "^7.0.6",
    "protobufjs": "^7.5.4",
    "puppeteer": "^22.0.0"
  }
}
